# Planview Portfolios API Configuration
PLANVIEW_API_URL=https://api.planview.com
PLANVIEW_API_KEY=your_api_key_here
PLANVIEW_TENANT_ID=your_tenant_id_here

# API Request Settings
API_TIMEOUT=30
MAX_RETRIES=3

# Server Settings
SERVER_NAME=planview-portfolios-mcp
SERVER_VERSION=0.1.0

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FILE=/path/to/logfile.log  # Optional: Enable file logging
